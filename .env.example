# ── Copy this file to .env and fill in your values ───────────────
# cp .env.example .env
# NEVER commit .env to git

# ── Gemini API (bắt buộc) ────────────────────────────────────────
# Lấy key tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy_replace_with_your_key

# ── Fallback keys (tùy chọn — dùng khi key chính hết quota) ──────
FALLBACK_KEY_1=
FALLBACK_KEY_2=

# ── Model (mặc định gemini-2.5-flash nếu để trống) ───────────────
GEMINI_MODEL=gemini-2.5-flash

# ── Timeouts ─────────────────────────────────────────────────────
# REQUEST_TIMEOUT=60
# MAX_RETRIES=3
