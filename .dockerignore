# ── Secrets ──────────────────────────────────────────────────────
# KHÔNG BAO GIỜ bake .env vào image (mount read-only khi runtime)
.env

# ── User data ─────────────────────────────────────────────────────
# Mount làm bind volumes khi chạy — không cần trong image
inputs/
outputs/
data/
logs/
Reports/

# ── Python artifacts ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg/
dist/
build/
.venv/
venv/
.pytest_cache/

# ── Backup files ──────────────────────────────────────────────────
*.bak*
*.tmp

# ── VCS & IDE ─────────────────────────────────────────────────────
.git/
.gitignore
.vscode/
.idea/
*.DS_Store

# ── Docs ──────────────────────────────────────────────────────────
# Không cần trong image — tiết kiệm layer size
readme.md
CHANGELOG.md
LICENSE